		"globals": "17.3.0",
		"jiti": "2.6.1",
		"tslib": "2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0"
	},
	"dependencies": {
		"@diaryx/wasm-node": "^1.2.0-dev.d069796",
		"obsidian": "^1.12.2"
