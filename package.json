{
	"name": "diaryx-obsidian",
	"version": "0.1.1",
	"description": "Maintains Diaryx workspace hierarchy (contents/part_of) when files are moved or renamed.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.30.1",
		"@types/node": "^25.3.3",
		"esbuild": "0.27.3",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "17.4.0",
		"jiti": "2.6.1",
		"tslib": "2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"dependencies": {
		"@diaryx/wasm-node": "^1.2.1-dev.81cd22f",
		"@extism/extism": "^2.0.0-rc13",
		"obsidian": "^1.12.3"
	}
}
